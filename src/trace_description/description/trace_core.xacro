<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="inertial_macros.xacro"/>

    <material name="white">
        <color rgba="1 1 1 1" />
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <!-- URDF CREATION NOTES: According to urdf creation standards for diff drive robots 
     we want the base_link to sit in between the wheels. We basically design our entire robot around the base_link because 
     I reckon it helps us with creating the controller and all the kinematics jazz-->

    <!-- BASE LINK -->

    <link name = "base_link">

    </link>

    <!-- CHASSIS LINK -->

    <joint name = "chassis_joint" type = "fixed">
        <parent link = "base_link"/>
        <child link = "chassis_link"/>
        <origin xyz = "-0.345 0 0.035"/> <!-- We want the chassis link to sit at the edge of the chassis (100 cm behind the wheels)-->
    </joint> 

    <!-- By default the visual of the link centers around the location of the joint
            so we offset its position in the origin tag to get it where we want it -->

    <link name = "chassis_link">
        <visual>
            <origin xyz = "0.26 -0.130 0.170"/> 
            <geometry>
                <!--<box size = "0.520 0.410 0.055"/>-->
                <mesh filename="package://trace_description/meshes/chassis.stl" />
            </geometry>
            <material name = "white"/>
        </visual>

        <collision>
            <origin xyz = "0.26 0 0.0275"/> 
            <geometry>
                <box size = "0.520 0.410 0.055"/>
            </geometry>
        </collision>

        <xacro:inertial_box mass="2.0" x="0.520" y="0.410" z="0.055">
            <origin xyz="0.26 0 0.0275" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>


    <!-- LEFT WHEEL LINK -->


    <!--By default cyliders are oriented along the x axis so we have to rotate them in the urdf so that they look right-->
    <!--Z axis of the wheels should also be pointing away from the robot-->

    <joint name = "left_wheel_joint" type = "continuous">
        <parent link = "base_link"/>
        <child link = "left_wheel_link"/>
        <origin xyz = "0 0.255 0" rpy = "-${pi/2} 0 0"/>
        <axis xyz = "0 0 1"/>
        <limit effort="0.05" velocity="10.0"/> <!-- Tag to limit torque and velocity within gazebo sim to make movement feel smooth-->
    </joint> 
    
    <link name = "left_wheel_link">
        <visual>
            <geometry>
                <cylinder radius = "0.0691" length="0.065"/>
            </geometry>
            <material name = "blue"/>
        </visual>

        <collision>
            <geometry>
                <sphere radius = "0.0691"/>
            </geometry>
        </collision>

        <xacro:inertial_cylinder mass="0.1" length="0.065" radius="0.0691">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <!-- RIGHT WHEEL LINK -->

    <joint name = "right_wheel_joint" type = "continuous">
        <parent link = "base_link"/>
        <child link = "right_wheel_link"/>
        <origin xyz = "0 -0.255 0" rpy = "${pi/2} 0 0"/>
        <axis xyz = "0 0 -1"/>
        <limit effort="0.05" velocity="10.0"/> <!-- Tag to limit torque and velocity within gazebo sim to make movement feel smooth-->
    </joint> 
    
    <link name = "right_wheel_link">
        <visual>
            <geometry>
                <cylinder radius = "0.0691" length="0.065"/>
            </geometry>
            <material name = "blue"/>
        </visual>

        <collision>
            <geometry>
                <sphere radius = "0.0691"/>
            </geometry>
        </collision>

        <xacro:inertial_cylinder mass="0.1" length="0.065" radius="0.0691">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>


    <!-- CASTER WHEEL LINK -->

    <joint name = "caster_wheel_joint" type = "fixed">
        <parent link = "chassis_link" />
        <child link = "caster_wheel_link"/>
        <origin xyz = "0 0 -0.035"/>
    </joint>

    <link name ="caster_wheel_link">
        <visual>
            <geometry>         
                <sphere radius = "0.0691"/>
            </geometry>
            <material name = "white"/>
        </visual>

        <collision>
            <geometry>
                <sphere radius = "0.0691"/>
            </geometry>
        </collision>

        <xacro:inertial_sphere mass="0.1" radius="0.0691">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <!-- BALL COLLECTION MECHANISM LINK -->

    <joint name = "ball_collection_mechanism_joint" type = "fixed">
        <parent link = "chassis_link" />
        <child link = "ball_collection_mechanism_link"/>
        <origin xyz = "0.580 0 -0.02"/>
    </joint>

    <link name ="ball_collection_mechanism_link">

        <visual>
            <geometry>
                <box size = "0.12 0.21 0.1"/>
            </geometry>
            <material name = "black"/>
        </visual>

        <collision>
            <origin xyz = "0 0 0"/> 
            <geometry>
                <box size = "0.12 0.21 0.1"/>
            </geometry>
        </collision>

        
    </link>


    <!-- Gazebo tag to make the caster wheel frictionless-->
    <gazebo reference="caster_wheel_link">
        <mu1 value="0.0"/>
        <mu2 value="0.0"/>
    </gazebo>



</robot>